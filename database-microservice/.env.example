# Database Microservice Configuration

# Authentication
API_KEY=your-secure-api-key-here

# Logging
LOG_LEVEL=INFO

# Database Connection Settings
MAX_CONNECTIONS=5
QUERY_TIMEOUT=30
CONNECTION_TIMEOUT=10

# Security
ENCRYPTION_KEY=auto-generated-if-not-provided

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Development Settings (optional)
DEBUG=false
RELOAD=false
